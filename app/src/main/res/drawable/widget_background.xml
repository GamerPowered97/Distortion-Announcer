<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Frosted glass background: deep dark semi-transparent tint -->
    <gradient
        android:startColor="#E61A1C24"
        android:endColor="#E6101016"
        android:angle="270" />
    <corners android:radius="16dp" />
    <!-- White translucent border to mimic glass edge refraction -->
    <stroke
        android:width="1.2dp"
        android:color="#4DFFFFFF" />
</shape>
